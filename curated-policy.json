{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Service": "quicksight.amazonaws.com"
      },
      "Action": [
        "s3:GetObject",
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::flight-pipeline-curated-013849273657",
        "arn:aws:s3:::flight-pipeline-curated-013849273657/*"
      ],
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "013849273657"
        }
      }
    }
  ]
}